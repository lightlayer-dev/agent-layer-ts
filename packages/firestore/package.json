  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm build"
  },
  "author": "Isaac Chang <chang.isaac97@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
