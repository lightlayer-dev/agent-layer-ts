  "dependencies": {
    "@agent-layer/core": "workspace:*"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/koa": "^2.15.0",
    "@types/koa__router": "^12.0.4",
    "express": "^4.18.0",
    "koa": "^2.15.0",
